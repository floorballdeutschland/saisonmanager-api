<% release = @transfer_request.request_type == 'release' %>
<h2><%= release ? 'Spielerfreigabe-Antrag abgelehnt' : 'Transferantrag abgelehnt' %></h2>

<p>Hallo,</p>

<p>
  der <%= release ? 'Spielerfreigabe-Antrag' : 'Transferantrag' %> für den folgenden Spieler wurde abgelehnt:
</p>

<p>
  <strong>Spieler:</strong> <%= @transfer_request.player.first_name %> <%= @transfer_request.player.last_name %><br>
  <strong>Abgebender Verein:</strong> <%= @transfer_request.former_club.name %>
</p>

<% if @transfer_request.rejection_reason.present? %>
<p>
  <strong>Begründung:</strong><br>
  <%= @transfer_request.rejection_reason %>
</p>
<% end %>

<p>
  Das Saisonmanager-Team<br>
  <a href="<%= frontend_base_url %>"><%= frontend_host %></a>
</p>
